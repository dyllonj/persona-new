{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/model_matrix.schema.json",
  "title": "Production/Open Model Matrix",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "matrix_name",
    "template_status",
    "real_run_ready",
    "drift_pairs",
    "standalone_instruct_models",
    "cross_family_comparisons",
    "metric_applicability"
  ],
  "properties": {
    "schema_version": {
      "const": "model_matrix_v1"
    },
    "matrix_name": {
      "type": "string",
      "minLength": 1
    },
    "template_status": {
      "type": "string",
      "enum": ["template_with_placeholders", "real_run_ready"]
    },
    "real_run_ready": {
      "type": "boolean"
    },
    "drift_pairs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/drift_pair"
      }
    },
    "standalone_instruct_models": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/model_entry"
      }
    },
    "cross_family_comparisons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/cross_family_comparison"
      }
    },
    "metric_applicability": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "drift_pairs",
        "standalone_instruct_models",
        "cross_family_comparisons"
      ],
      "properties": {
        "drift_pairs": {
          "$ref": "#/$defs/metric_policy"
        },
        "standalone_instruct_models": {
          "$ref": "#/$defs/metric_policy"
        },
        "cross_family_comparisons": {
          "$ref": "#/$defs/metric_policy"
        }
      }
    }
  },
  "$defs": {
    "token_kl_applicability": {
      "type": "string",
      "enum": ["canonical_possible", "diagnostic_only", "not_applicable"]
    },
    "model_entry": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "model_id",
        "role",
        "provider_or_endpoint",
        "serving_stack",
        "expected_tokenizer_family",
        "expected_chat_template_policy",
        "license_review_required",
        "token_kl_applicability",
        "token_kl_reason_code",
        "required_revision_or_hash",
        "notes"
      ],
      "properties": {
        "model_id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "base",
            "instruct",
            "standalone_instruct",
            "judge",
            "embedding",
            "nli"
          ]
        },
        "provider_or_endpoint": {
          "type": "string",
          "minLength": 1
        },
        "serving_stack": {
          "type": "string",
          "minLength": 1
        },
        "expected_tokenizer_family": {
          "type": "string",
          "minLength": 1
        },
        "expected_chat_template_policy": {
          "type": "string",
          "minLength": 1
        },
        "license_review_required": {
          "type": "boolean"
        },
        "license_review_status": {
          "type": "string",
          "enum": ["approved", "pending", "blocked", "not_required"]
        },
        "license_reviewed_by": {
          "type": "string",
          "minLength": 1
        },
        "license_reviewed_at": {
          "type": "string",
          "minLength": 1
        },
        "license_terms_url": {
          "type": "string",
          "minLength": 1
        },
        "license_source_url": {
          "type": "string",
          "minLength": 1
        },
        "redistribution_or_usage_notes": {
          "type": "string",
          "minLength": 1
        },
        "license_review_evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "token_kl_applicability": {
          "$ref": "#/$defs/token_kl_applicability"
        },
        "token_kl_reason_code": {
          "type": "string",
          "minLength": 1
        },
        "required_revision_or_hash": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "alignment_contract": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "same_tokenizer_family_required",
        "same_vocabulary_required",
        "prompt_rendering_hash_required",
        "chat_template_policy_match_required",
        "fixed_continuation_scoring_required",
        "comparable_next_token_logprobs_required",
        "canonical_token_kl_status_before_proof"
      ],
      "properties": {
        "same_tokenizer_family_required": {
          "type": "boolean"
        },
        "same_vocabulary_required": {
          "type": "boolean"
        },
        "prompt_rendering_hash_required": {
          "type": "boolean"
        },
        "chat_template_policy_match_required": {
          "type": "boolean"
        },
        "fixed_continuation_scoring_required": {
          "type": "boolean"
        },
        "comparable_next_token_logprobs_required": {
          "type": "boolean"
        },
        "canonical_token_kl_status_before_proof": {
          "const": "not_applicable"
        }
      }
    },
    "drift_pair": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "pair_id",
        "family",
        "comparison_type",
        "base_model",
        "instruct_model",
        "token_kl_applicability",
        "token_kl_reason_code",
        "alignment_contract",
        "notes"
      ],
      "properties": {
        "pair_id": {
          "type": "string",
          "minLength": 1
        },
        "family": {
          "type": "string",
          "minLength": 1
        },
        "comparison_type": {
          "const": "same_family_base_instruct"
        },
        "base_model": {
          "$ref": "#/$defs/model_entry"
        },
        "instruct_model": {
          "$ref": "#/$defs/model_entry"
        },
        "token_kl_applicability": {
          "$ref": "#/$defs/token_kl_applicability"
        },
        "token_kl_reason_code": {
          "type": "string",
          "minLength": 1
        },
        "alignment_contract": {
          "$ref": "#/$defs/alignment_contract"
        },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "cross_family_comparison": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "comparison_id",
        "comparison_type",
        "left_model",
        "right_model",
        "token_kl_applicability",
        "token_kl_reason_code",
        "notes"
      ],
      "properties": {
        "comparison_id": {
          "type": "string",
          "minLength": 1
        },
        "comparison_type": {
          "const": "cross_family"
        },
        "left_model": {
          "$ref": "#/$defs/model_entry"
        },
        "right_model": {
          "$ref": "#/$defs/model_entry"
        },
        "token_kl_applicability": {
          "$ref": "#/$defs/token_kl_applicability"
        },
        "token_kl_reason_code": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "metric_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "persona_adherence",
        "behavioral_consistency_f1",
        "token_kl"
      ],
      "properties": {
        "persona_adherence": {
          "type": "string",
          "minLength": 1
        },
        "behavioral_consistency_f1": {
          "type": "string",
          "minLength": 1
        },
        "token_kl": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
