{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/candidate_persona.schema.json",
  "title": "Sprint 6 Candidate Persona",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_schema_version",
    "candidate_id",
    "persona_id",
    "generation_method",
    "created_at",
    "generator_version",
    "source_trace",
    "validation_status",
    "promotion_status",
    "low_confidence_flags",
    "source",
    "persona_spec",
    "seed_prompt",
    "expected_behavior",
    "variants",
    "annotation"
  ],
  "properties": {
    "candidate_schema_version": {
      "type": "string",
      "const": "sprint6_candidate_persona_v1"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,80}$"
    },
    "persona_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,80}$"
    },
    "generation_method": {
      "type": "string",
      "enum": ["deterministic_fixture"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "source_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_id",
        "source_type",
        "source_id",
        "template_id",
        "template_version",
        "input_index",
        "input_hash",
        "source_inventory_key",
        "derivation_notes"
      ],
      "properties": {
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "enum": ["local_synthetic_blueprint"]
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "template_id": {
          "type": "string",
          "minLength": 1
        },
        "template_version": {
          "type": "string",
          "minLength": 1
        },
        "input_index": {
          "type": "integer",
          "minimum": 1
        },
        "input_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "source_inventory_key": {
          "type": "string",
          "minLength": 1
        },
        "derivation_notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "validation_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "validator_version", "validated_at", "checks"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["generated_unvalidated", "schema_validated", "needs_review", "rejected"]
        },
        "validator_version": {
          "type": "string",
          "minLength": 1
        },
        "validated_at": {
          "type": "string",
          "format": "date-time"
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "promotion_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_promoted", "ready_for_review", "blocked_from_promotion"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "low_confidence_flags": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "persona_spec": {
      "$ref": "#/$defs/persona_spec"
    },
    "seed_prompt": {
      "$ref": "#/$defs/seed_prompt"
    },
    "expected_behavior": {
      "$ref": "#/$defs/behavior_labels"
    },
    "variants": {
      "$ref": "#/$defs/variants"
    },
    "annotation": {
      "$ref": "#/$defs/annotation"
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset",
        "source_url",
        "license",
        "license_url",
        "split",
        "source_persona_id",
        "retrieved_at",
        "revision_or_hash",
        "modification_notes",
        "redistribution_notes"
      ],
      "properties": {
        "dataset": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": "string",
          "minLength": 1
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "license_url": {
          "type": "string",
          "minLength": 1
        },
        "split": {
          "type": "string",
          "minLength": 1
        },
        "source_persona_id": {
          "type": "string",
          "minLength": 1
        },
        "retrieved_at": {
          "type": "string",
          "format": "date"
        },
        "revision_or_hash": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "modification_notes": {
          "type": "string",
          "minLength": 1
        },
        "redistribution_notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "persona_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "facts", "traits", "forbidden_behaviors"],
      "properties": {
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "facts": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "traits": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tone", "style", "values"],
          "properties": {
            "tone": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "style": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "values": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "forbidden_behaviors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "seed_prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt_id", "text", "intent", "topic"],
      "properties": {
        "prompt_id": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "topic": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "behavior_labels": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stance", "primary_action", "secondary_modifiers"],
      "properties": {
        "stance": {
          "type": "string",
          "minLength": 1
        },
        "primary_action": {
          "type": "string",
          "minLength": 1
        },
        "secondary_modifiers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "variants": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "$ref": "#/$defs/variant"
      },
      "allOf": [
        {
          "contains": {
            "properties": {
              "type": {
                "const": "canonical"
              }
            },
            "required": ["type"]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": {
              "type": {
                "const": "paraphrase"
              }
            },
            "required": ["type"]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": {
              "type": {
                "const": "negation_preserving"
              }
            },
            "required": ["type"]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": {
              "type": {
                "const": "distractor"
              }
            },
            "required": ["type"]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": {
              "type": {
                "const": "instruction_prefix"
              }
            },
            "required": ["type"]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": {
              "type": {
                "const": "temperature_robust"
              }
            },
            "required": ["type"]
          },
          "minContains": 1,
          "maxContains": 1
        }
      ]
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variant_id", "type", "text"],
      "properties": {
        "variant_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "canonical",
            "paraphrase",
            "negation_preserving",
            "distractor",
            "instruction_prefix",
            "temperature_robust"
          ]
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "equivalence_status": {
              "type": "string",
              "enum": ["manual_fixture_check"]
            }
          }
        },
        "distractor_meta": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "category": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["category"]
        },
        "prefix_meta": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "style": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["style"]
        },
        "generation_meta": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "generator": {
              "type": "string",
              "const": "human_fixture_author"
            },
            "selected_from": {
              "type": "integer",
              "minimum": 1
            }
          },
          "required": ["generator", "selected_from"]
        }
      }
    },
    "annotation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gold_labels", "safety_class", "review_status"],
      "properties": {
        "gold_labels": {
          "$ref": "#/$defs/behavior_labels"
        },
        "safety_class": {
          "type": "string",
          "const": "benign"
        },
        "review_status": {
          "type": "string",
          "enum": ["fixture_reviewed", "validated"]
        }
      }
    }
  }
}
