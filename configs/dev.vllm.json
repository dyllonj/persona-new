{
  "schema_version": "run_config_template_v1",
  "template_status": "fill_before_use",
  "stage": "dev",
  "serving_stack": "vllm",
  "adapter": "vllm",
  "base_url": "http://localhost:8000/v1",
  "persona_path": "data/personas.full.jsonl",
  "limit_personas": 50,
  "variants_per_persona": 6,
  "model_count": 2,
  "seed_count": 2,
  "seeds": [1, 2],
  "expected_generation_calls": 1200,
  "run_id": "dev_50_<YYYYMMDD>",
  "output_dir": "results/dev_50_<YYYYMMDD>",
  "report_dir": "reports/dev_50_<YYYYMMDD>",
  "models": {
    "base": {
      "id": "<base-model-id>",
      "revision_or_hash": "<base-model-revision-or-hash>"
    },
    "tuned": {
      "id": "<tuned-model-id>",
      "revision_or_hash": "<tuned-model-revision-or-hash>"
    }
  },
  "runtime_metadata": {
    "tokenizer_name": "<tokenizer-name>",
    "tokenizer_hash": "<sha256-tokenizer-or-package-hash>",
    "chat_template_hash": "<sha256-chat-template-hash>",
    "serving_stack_version": "<vllm-version>",
    "gpu_cuda_driver": "<gpu-cuda-driver-summary>"
  },
  "decoding_params": {
    "temperature": 0.0,
    "max_tokens": 140
  },
  "guardrails": {
    "required_preflight_command": "python3 persona_eval.py preflight --stage dev --persona-count 50 --variants-per-persona 6 --model-count 2 --seed-count 2 --smoke-evidence <smoke-evidence.json>",
    "smoke_evidence_required": true,
    "explicit_smoke_override_allowed": true,
    "explicit_smoke_override_requires_reason": true,
    "do_not_execute_until_preflight_passes": true,
    "do_not_modify_data_personas_full_jsonl": true,
    "do_not_bypass_staged_execution_caps": true
  }
}
