    "reason": "Canonical Token-KL remains unavailable until fixed aligned continuation scoring is proven."
  },
  "required_manifest_fields": [
    "persona_jsonl_hash",
    "promotion_manifest_hash",
    "model_base",
    "model_tuned",
    "model_base_revision_or_hash",
    "model_tuned_revision_or_hash",
    "tokenizer_name",
    "tokenizer_hash",
    "chat_template_hash",
    "serving_stack",
    "serving_stack_version",
    "gpu_cuda_driver",
    "raw_request_response_logging_status"
  ]
}
